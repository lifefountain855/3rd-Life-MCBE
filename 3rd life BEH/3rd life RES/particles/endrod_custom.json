{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "twr:endrod_custom",
            "basic_render_parameters": {
                "material": "particles_blend",
                "texture": "textures/particle/particles"
            }
        },
        "components": {
            "minecraft:emitter_rate_manual": {
                "max_particles": 50
            },
            "minecraft:emitter_lifetime_expression": {
                "activation_expression": 1,
                "expiration_expression": 0
            },
            "minecraft:emitter_shape_point": {
                "direction": [
                    0.0,
                    -1.0,
                    0.0
                ]
            },
            "minecraft:particle_initial_speed": 0.0,
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": "Math.random(1.2, 1.6)"
            },
            "minecraft:particle_motion_parametric": {
                "relative_position": [
                  "Math.cos((variable.particle_age * 360) + (variable.particle_random_1 * 360)/4)",
                  "variable.particle_age",
                  "Math.sin((variable.particle_age * 360) + (variable.particle_random_1 * 360)/4)"
                ]
              },
            "minecraft:particle_appearance_billboard": {
                "size": [
                    "(variable.particle_random_1 * 0.5f + 0.5f) * 0.2",
                    "(variable.particle_random_1 * 0.5f + 0.5f) * 0.2"
                ],
                "facing_camera_mode": "lookat_xyz",
                "uv": {
                    "texture_width": 128,
                    "texture_height": 128,
                    "flipbook": {
                        "base_UV": [
                            56,
                            88
                        ],
                        "size_UV": [
                            8,
                            8
                        ],
                        "step_UV": [
                            -8,
                            0
                        ],
                        "frames_per_second": 16,
                        "max_frame": 8,
                        "stretch_to_lifetime": true,
                        "loop": false
                    }
                }
            },
            "minecraft:particle_appearance_tinting": {
                "color": [
                    "v.particle_age/2",
                    "v.particle_age/2",
                    "v.particle_age/1.5"
                ]
            }
        }
    }
}