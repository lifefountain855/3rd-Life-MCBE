{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.shift": {
      "states": {
        "default": {
          "transitions": [
            {
              "state_1": "query.is_sneaking"
            }
          ],
          "on_entry": ["/tag @s remove shift"],
          "on_exit": ["/tag @s add shift"]
        },
        "state_1": {
          "transitions": [
            {
              "default": "!query.is_sneaking"
            }
          ]
        }
      }
    }
  }
}