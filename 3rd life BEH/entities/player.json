{
    "format_version": "1.16.0",
    "minecraft:entity": {
      "description": {
        "identifier": "minecraft:player",
        "is_spawnable": false,
        "is_summonable": false,
        "is_experimental": false,
        "scripts": {
          "animate": [
            "shift",
            "death",
            "jump"
          ]
        },
        "animations": {
          "shift": "controller.animation.shift",
          "death":"controller.animation.death",
          "jump":"controller.animation.jump"
        }
      },
      "component_groups": {
        "player":{
          "minecraft:variant":1
        },
        "spec":{
          "minecraft:damage_sensor":{
            "triggers":{
              "cause":"all",
              "deals_damage": false
            }
          },
          "minecraft:variant":1
        },
        //effects
        "shadow:no-invis": {
          "minecraft:spell_effects": {
            "remove_effects": "invisibility"
          }
        },
        "shadow:no-strength": {
          "minecraft:spell_effects": {
            "remove_effects": "strength"
          }
        },
        "shadow:no-poison/hunger": {
          "minecraft:spell_effects": {
            "remove_effects": [
              "poison",
              "hunger"
            ]
          }
        },
        "shadow:no-levitation": {
          "minecraft:spell_effects": {
            "remove_effects": [
              "levitation",
              "slow_falling"
            ]
          }
        },
        "shadow:no-slow_falling": {
          "minecraft:spell_effects": {
            "remove_effects": "slow_falling"
          }
        },
        "shadow:no-jumpboost": {
          "minecraft:spell_effects": {
            "remove_effects": "jump_boost"
          }
        },
        "shadow:no-water_breathing": {
          "minecraft:spell_effects": {
            "remove_effects": "water_breathing"
          }
        },
        "shadow:no-conduit_power": {
          "minecraft:spell_effects": {
            "remove_effects": "conduit_power"
          }
        },
        "shadow:no-weakness": {
          "minecraft:spell_effects": {
            "remove_effects": "weakness"
          }
        },
        "minecraft:add_bad_omen": {
          "minecraft:spell_effects": {
            "add_effects": [
              {
                "effect": "bad_omen",
                "duration": 6000,
                "display_on_screen_animation": true
              }
            ]
          },
          "minecraft:timer": {
            "time": [
              0.0,
              0.0
            ],
            "looping": false,
            "time_down_event": {
              "event": "minecraft:clear_add_bad_omen",
              "target": "self"
            }
          }
        },
        "minecraft:clear_bad_omen_spell_effect": {
          "minecraft:spell_effects": {}
        },
        "minecraft:raid_trigger": {
          "minecraft:raid_trigger": {
            "triggered_event": {
              "event": "minecraft:remove_raid_trigger",
              "target": "self"
            }
          },
          "minecraft:spell_effects": {
            "remove_effects": "bad_omen"
          }
        }
      },
      "components": {
        "minecraft:experience_reward": {
          "on_death": "Math.Min(query.player_level * 7, 100)"
        },
        "minecraft:type_family": {
          "family": [
            "player"
          ]
        },
        "minecraft:is_hidden_when_invisible": {},
        "minecraft:loot": {
          "table": "loot_tables/empty.json"
        },
        "minecraft:collision_box": {
          "width": 0.6,
          "height": 1.8
        },
        "minecraft:can_climb": {},
        "minecraft:movement": {
          "value": 0.1
        },
        "minecraft:hurt_on_condition": {
          "damage_conditions": [
            {
              "filters": {
                "test": "in_lava",
                "subject": "self",
                "operator": "==",
                "value": true
              },
              "cause": "lava",
              "damage_per_tick": 4
            }
          ]
        },
        "minecraft:attack": {
          "damage": 1
        },
        "minecraft:player.saturation": {
          "value": 20
        },
        "minecraft:player.exhaustion": {
          "value": 0,
          "max": 4
        },
        "minecraft:player.level": {
          "value": 0,
          "max": 24791
        },
        "minecraft:player.experience": {
          "value": 0,
          "max": 1
        },
        "minecraft:breathable": {
          "total_supply": 15,
          "suffocate_time": -1,
          "inhale_time": 3.75,
          "generates_bubbles": false
        },
        "minecraft:nameable": {
          "always_show": true,
          "allow_name_tag_renaming": false
        },
        "minecraft:physics": {},
        "minecraft:pushable": {
          "is_pushable": false,
          "is_pushable_by_piston": true
        },
        "minecraft:insomnia": {
          "days_until_insomnia": 3
        },
        "minecraft:rideable": {
          "seat_count": 2,
          "family_types": [
            "parrot_tame"
          ],
          "pull_in_entities": true,
          "seats": [
            {
              "position": [
                0.4,
                -0.2,
                -0.1
              ],
              "min_rider_count": 0,
              "max_rider_count": 0,
              "lock_rider_rotation": 0
            },
            {
              "position": [
                -0.4,
                -0.2,
                -0.1
              ],
              "min_rider_count": 1,
              "max_rider_count": 2,
              "lock_rider_rotation": 0
            }
          ]
        },
        "minecraft:conditional_bandwidth_optimization": {},
        "minecraft:scaffolding_climber": {},
        "minecraft:environment_sensor": {
          "triggers": {
            "filters": {
              "all_of": [
                {
                  "test": "has_mob_effect",
                  "subject": "self",
                  "value": "bad_omen"
                },
                {
                  "test": "is_in_village",
                  "subject": "self",
                  "value": true
                }
              ]
            },
            "event": "minecraft:trigger_raid"
          }
        }
      },
      "events": {
        "spec":{
          "add":{
            "component_groups":["spec"]
          }
        },
        "player":{
          "add":{
            "component_groups":["player"]
          },
          "remove":{
            "component_groups":["spec"]
          }
        },
        //effects
        "shadow:no-invis": {
          "add": {
            "component_groups": [
              "shadow:no-invis"
            ]
          }
        },
        "shadow:no-strength": {
          "add": {
            "component_groups": [
              "shadow:no-strength"
            ]
          }
        },
        "shadow:no-poison/hunger": {
          "add": {
            "component_groups": [
              "shadow:no-poison/hunger"
            ]
          }
        },
        "shadow:no-weakness": {
          "add": {
            "component_groups": [
              "shadow:no-weakness"
            ]
          }
        },
        "shadow:no-levitation": {
          "add": {
            "component_groups": [
              "shadow:no-levitation"
            ]
          }
        },
        "shadow:no-jumpboost": {
          "add": {
            "component_groups": [
              "shadow:no-jumpboost"
            ]
          }
        },
        "shadow:no-water_breathing": {
          "add": {
            "component_groups": [
              "shadow:no-water_breathing"
            ]
          }
        },
        "shadow:no-conduit_power": {
          "add": {
            "component_groups": [
              "shadow:no-conduit_power"
            ]
          }
        }
      }
    }
  }